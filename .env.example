# LifeOS — template only. Copy the lines you need into apps/web/.env.local
# (Next.js loads .env* from the app directory). Never commit real secrets.
#
# Mock mode: the app must be able to run without OpenAI or Google credentials
# (e.g. stubs/mocks) until those integrations are wired; leave those vars unset or empty.
#
# NEXT_PUBLIC_* variables may be exposed to the browser (bundled by Next.js).

# Supabase — public (safe for browser; still use project anon key, not service role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only. The service role key must never be used client-side.
SUPABASE_SERVICE_ROLE_KEY=server_only_do_not_expose

# OpenAI — server only. Optional until AI integrations are enabled (e.g. “phase 4”).
OPENAI_API_KEY=server_only_optional_until_phase_4
AI_PARSE_CAPTURE_ENABLED=true

# Model tiers — server-side resolution; do not hardcode model IDs in application logic.
AI_MODEL_CHEAP=
AI_MODEL_STANDARD=
AI_MODEL_STRONG=

# Google OAuth (Calendar, etc.) — server only; use only in Route Handlers / Server Actions.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
