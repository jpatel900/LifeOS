{
  "$comment": "LifeOS design tokens. Dark is the default theme; light is a toggle. Accent tokens are derived per active area at runtime (see derive + accent.js), not stored.",
  "theme": {
    "dark": {
      "bd": "#0c0d10", "sf": "#15171c", "sf2": "#1b1e25", "sf3": "#21252d",
      "ink": "#f2f1ec", "mut": "#9b9ca4", "fnt": "#686a73",
      "ln": "#23262e", "ln2": "#2c303a",
      "btn": "#f2f1ec", "btnFg": "#15171c", "track": "#262a33"
    },
    "light": {
      "bd": "#e7e4db", "sf": "#fbfaf7", "sf2": "#ffffff", "sf3": "#f4f1ea",
      "ink": "#18170f", "mut": "#6f6d64", "fnt": "#a8a69d",
      "ln": "#efece5", "ln2": "#e2dfd6",
      "btn": "#18170f", "btnFg": "#ffffff", "track": "#ece9e1"
    }
  },
  "status": {
    "amber": { "role": "triage / needs decision", "dark": { "fg": "#e3ad52", "sf": "#2c2615", "ring": "#51441f" }, "light": { "fg": "#b5791f", "sf": "#f6ecd6", "ring": "#ecdcbb" } },
    "blue":  { "role": "plan / someday",          "dark": { "fg": "#7aa2dd", "sf": "#172838", "ring": "#2e486a" }, "light": { "fg": "#3f6fb8", "sf": "#e7eefa", "ring": "#d4e0f2" } },
    "green": { "role": "done / healthy",          "dark": { "fg": "#6fb98c", "sf": "#14301f", "ring": "#295036" }, "light": { "fg": "#4a8c63", "sf": "#e4efe8", "ring": "#d2e6da" } }
  },
  "accentPalette": ["#6b78e8", "#3f8fd6", "#3fae8f", "#5aa84a", "#d9a23f", "#d9624a", "#c44d80", "#b066d9"],
  "derive": {
    "$comment": "acc = the active area's stored base hex. Compute the rest from it. mix(a,b,t) = per-channel linear blend; lum = WCAG relative luminance.",
    "acc2":   "mix(acc, dark ? '#ffffff' : '#000000', 0.16)",
    "accSf":  "mix(acc, sf2, dark ? 0.80 : 0.86)",
    "accRng": "mix(acc, sf2, dark ? 0.50 : 0.66)",
    "onAcc":  "lum(acc) > 0.55 ? '#1a1a14' : '#ffffff'",
    "cardBg": "mix(areaColor, sf2, dark ? 0.83 : 0.88)"
  },
  "ring": { "focusRadius": 104, "reviewRadius": 86, "dash": "2*PI*r", "offset": "dash * (1 - value/total)" },
  "band": { "weight": "max(1, count) + 0.6" },
  "type": {
    "ui": { "family": "Hanken Grotesk", "weights": [400, 500, 600, 700, 800] },
    "mono": { "family": "IBM Plex Mono", "weights": [400, 500, 600], "usedFor": "clocks, counts, kicker labels, est/when" }
  },
  "layout": { "maxWidth": { "web": 1000, "mobile": 412 }, "radius": 22, "collapseToOneColumnOnMobile": ["plan", "review", "overview"] }
}
